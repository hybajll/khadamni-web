<!doctype html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>CV</title>
    <style>
        * { box-sizing: border-box; }
        body {
            font-family: DejaVu Sans, Arial, sans-serif;
            font-size: 12px;
            color: #0f172a;
            line-height: 1.35;
        }
        .header {
            padding: 18px 18px 12px 18px;
            border-bottom: 2px solid #ff8c00;
        }
        .name {
            font-size: 20px;
            font-weight: 800;
            margin: 0;
        }
        .meta {
            margin-top: 4px;
            color: #334155;
            font-size: 11px;
        }
        .meta span { margin-right: 10px; }
        .title {
            margin-top: 8px;
            font-weight: 700;
            color: #0a2340;
        }
        .content {
            padding: 14px 18px 18px 18px;
        }
        .section {
            margin-bottom: 14px;
        }
        .section h2 {
            margin: 0 0 6px 0;
            font-size: 12px;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: #0a2340;
        }
        ul {
            margin: 0;
            padding-left: 16px;
        }
        li { margin: 0 0 4px 0; }
        .footer {
            position: fixed;
            bottom: 10px;
            left: 18px;
            right: 18px;
            font-size: 10px;
            color: #64748b;
            text-align: right;
        }
    </style>
</head>
<body>
<div class="header">
    <p class="name">
        {% if user and (user.prenom or user.nom) %}
            {{ (user.prenom ?: '') ~ ' ' ~ (user.nom ?: '') }}
        {% else %}
            {{ user.email }}
        {% endif %}
    </p>
    <div class="meta">
        <span>Email: {{ user.email }}</span>
        <span>Généré: {{ generated_at|date('d/m/Y') }}</span>
    </div>
    <div class="title">{{ cv.titre }}</div>
</div>

<div class="content">
    {% for section in sections %}
        <div class="section">
            <h2>{{ section.title }}</h2>
            <ul>
                {% for item in section.items %}
                    <li>{{ item }}</li>
                {% endfor %}
            </ul>
        </div>
    {% else %}
        <div class="section">
            <h2>CV</h2>
            <div style="white-space: pre-wrap;">{{ (cv.contenuAmeliore ?: cv.contenuOriginal) }}</div>
        </div>
    {% endfor %}
</div>

<div class="footer">Khadamni — خدمني</div>
</body>
</html>

