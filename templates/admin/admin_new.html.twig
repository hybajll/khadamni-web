{% extends 'base.html.twig' %}

{% block title %}Admin - New Admin{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
        <div>
            <h1 class="h4 mb-1 text-darken">Ajouter un administrateur</h1>
            <div class="text-muted">Création manuelle d’un admin.</div>
        </div>
        <a href="{{ path('app_admin_admins') }}" class="btn btn-secondary">Retour</a>
    </div>

    <div class="card">
        <div class="card-body p-4">
            {{ form_start(form) }}

            <div class="row g-3">
                <div class="col-md-6">
                    {{ form_row(form.nom, {attr: {class: 'form-control'}}) }}
                </div>
                <div class="col-md-6">
                    {{ form_row(form.prenom, {attr: {class: 'form-control'}}) }}
                </div>
            </div>

            <div class="mt-3">
                {{ form_row(form.email, {attr: {class: 'form-control'}}) }}
            </div>

            <div class="mt-3">
                {{ form_row(form.role, {attr: {class: 'form-select'}}) }}
            </div>

            <div class="mt-3">
                {{ form_row(form.plainPassword, {attr: {class: 'form-control'}}) }}
            </div>

            <div class="mt-4 d-flex gap-2">
                <a href="{{ path('app_admin_admins') }}" class="btn btn-secondary">Annuler</a>
                <button type="submit" class="btn btn-primary">Créer</button>
            </div>

            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}

