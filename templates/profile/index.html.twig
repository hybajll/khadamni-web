{% extends 'base.html.twig' %}

{% block title %}Mon Profil{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-12">
            <div class="p-4 rounded-4 bg-cream shadow-sm">
                <h1 class="mb-2 text-darken">Mon Profil</h1>
                <p class="text-muted mb-0">Consultez et mettez à jour vos informations personnelles.</p>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h5 class="card-title mb-3 text-darken">Informations personnelles</h5>

                    <div class="row">
                        <div class="col-sm-6">
                            <p><strong>Nom :</strong> {{ user.nom ?: '-' }}</p>
                        </div>
                        <div class="col-sm-6">
                            <p><strong>Prénom :</strong> {{ user.prenom ?: '-' }}</p>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-sm-6">
                            <p><strong>Email :</strong> {{ user.email }}</p>
                        </div>
                        <div class="col-sm-6">
                            <p><strong>Type :</strong>
                                {% if user.type == 'etudiant' %}Étudiant
                                {% elseif user.type == 'diplome' %}Diplômé
                                {% else %}Administrateur{% endif %}
                            </p>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-sm-6">
                            <p><strong>Statut :</strong> {{ user.active ? 'Actif' : 'Inactif' }}</p>
                        </div>
                        <div class="col-sm-6">
                            <p><strong>Inscrit le :</strong> {{ user.localDateTime ? user.localDateTime|date('d/m/Y H:i') : 'N/A' }}</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Actions</h5>
                </div>
                <div class="card-body">
                    <a href="{{ path('app_profile_edit') }}" class="btn btn-primary w-100 mb-2">
                        <i class="fas fa-edit"></i> Modifier mon profil
                    </a>
                    <a href="{{ path('app_user_home') }}" class="btn btn-secondary w-100">
                        <i class="fas fa-arrow-left"></i> Retour à l'accueil
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
