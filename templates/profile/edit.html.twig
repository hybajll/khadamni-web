{% extends 'base.html.twig' %}

{% block title %}Modifier mon profil{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="rounded-4 bg-cream shadow-sm p-4 mb-4">
        <h1 class="h4 mb-1 text-darken">Modifier mon profil</h1>
        <p class="text-muted mb-0">Mettez à jour vos informations personnelles.</p>
        <nav aria-label="breadcrumb" class="mt-3">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="{{ path('app_user_home') }}">Accueil</a></li>
                <li class="breadcrumb-item"><a href="{{ path('app_profile') }}">Mon profil</a></li>
                <li class="breadcrumb-item active" aria-current="page">Modifier</li>
            </ol>
        </nav>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-body p-4">
                    {{ form_start(form) }}

                    <div class="row g-3">
                        <div class="col-md-6">
                            {{ form_row(form.nom, {attr: {class: 'form-control'}}) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.prenom, {attr: {class: 'form-control'}}) }}
                        </div>
                    </div>

                    <div class="mt-3">
                        {{ form_row(form.email, {attr: {class: 'form-control'}}) }}
                    </div>

                    <div class="mt-3">
                        {{ form_row(form.plainPassword, {attr: {class: 'form-control'}}) }}
                        <div class="form-text">Laissez vide pour conserver le mot de passe actuel.</div>
                    </div>

                    <div class="mt-4 d-flex gap-2">
                        <a href="{{ path('app_profile') }}" class="btn btn-secondary">Annuler</a>
                        <button type="submit" class="btn btn-primary">Enregistrer</button>
                    </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
